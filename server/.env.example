# ==========================================================
# PersonalAIBotV2 — Server Configuration
# ==========================================================
# Copy this file to .env:  cp .env.example .env
# Or run install.bat / install.sh — it auto-generates .env
# ==========================================================

# ===================
# Server
# ===================
PORT=3000
NODE_ENV=development
# TRUST_PROXY=1

# ===================
# Logging
# ===================
LOG_LEVEL=info
HTTP_CONSOLE_MODE=errors
SWARM_VERBOSE_LOGS=0

# ===================
# Security Keys
# ===================
# IMPORTANT: These are auto-generated by install.bat/install.sh
# If you create .env manually, generate secure values:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
ENCRYPTION_KEY=
JWT_SECRET=
CRED_SECRET=

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===================
# Playwright (Web Tools)
# ===================
HEADLESS=false
SLOW_MO=0

# ===================
# Swarm / Jarvis Settings
# ===================
JARVIS_MULTIPASS=0
JARVIS_TERMINAL_DIRECT_MODE=1
JARVIS_ENABLE_ENGLISH_HANDOFF=0
JARVIS_MAX_STAGE_A_LANES=5
SWARM_CLI_TASK_TIMEOUT_MS=120000
SWARM_CLI_SHELL_STYLE_MODE=1
SWARM_LOCAL_SYNTHESIS=1
SWARM_ENABLE_SUPERVISOR_ACTIONS=1
SWARM_ENABLE_ASSIST_TASKS=0
SWARM_ENABLE_PREEMPTIVE_REROUTE=1
SWARM_ASSIST_SLOW_TASK_MS=20000
SWARM_MAX_SUPERVISOR_FOLLOWUPS=2
SWARM_CLI_ADAPTIVE_MAX_ATTEMPTS=2
SWARM_CLI_ADAPTIVE_TIMEOUT_STEP_MS=45000
SWARM_COMMAND_TIMEOUT_MS=120000
SWARM_LANE_TIMEOUT_MS=120000
SWARM_PERSISTENT_CLI=0
SWARM_SKIP_REVIEWER_GATE=1
SWARM_SKIP_BACKGROUND_ENRICHMENT=1

# ===================
# NOTE: API Keys & Bot Tokens
# ===================
# AI Provider keys (Gemini, OpenAI, etc.) and messaging
# platform tokens (Telegram, LINE, Facebook) are stored
# in the DATABASE — configure them via the Dashboard UI
# after first launch at http://localhost:3000
#
# Do NOT put API keys or bot tokens in this file.
# This keeps credentials secure and avoids accidental leaks.
